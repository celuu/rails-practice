<%= form_with model: @post do |f| %>
  <% if @post.errors.any? %>
    <%@post.errors.full_messages.each do |message|%>
    <li><%= message %>
    <%end%>
  <%end%>


  <div>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :body %><br>
    <%= f.text_area :body %>
  </div>

  <%= f.submit "Update Post" %>
<% end %>